{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "affine-frontend",
      "runtimeExecutable": "yarn",
      "runtimeArgs": ["affine", "bundle", "--dev", "-p", "web"],
      "port": 8080
    },
    {
      "name": "manut-web-static",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "-y",
        "http-server",
        "packages/frontend/apps/web/dist",
        "-p",
        "8090",
        "-c-1",
        "--proxy",
        "http://localhost:8090?"
      ],
      "port": 8090
    },
    {
      "name": "affine-server",
      "runtimeExecutable": "yarn",
      "runtimeArgs": ["affine", "server", "dev"],
      "port": 3010
    },
    {
      "name": "affine-prisma-studio",
      "runtimeExecutable": "yarn",
      "runtimeArgs": ["affine", "server", "prisma", "studio"],
      "port": 5555
    },
    {
      "name": "manut-landing",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "cd manut-landing && exec npm run dev"],
      "port": 3000
    }
  ]
}
