}

enum MnRoutineRunTrigger {
  MANUAL
  SCHEDULED
  MCP
}

enum MnRoutineRunStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
  TIMED_OUT
}

model MnProject {
  id              String          @id @default(uuid()) @db.VarChar
  workspaceId     String          @map("workspace_id") @db.VarChar
  name            String          @db.VarChar
  description     String?         @db.Text
  status          MnProjectStatus @default(ACTIVE)
  sortOrder       Int             @default(0) @map("sort_order")
  createdByUserId String?         @map("created_by_user_id") @db.VarChar
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(3)

  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy   User?             @relation("MnProjectCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  members     MnProjectMember[]
  tasks       MnTask[]
  agents      MnAgent[]
  costEvents  MnCostEvent[]
  budgets     MnBudget[]
  goals       MnGoal[]
  approvals   MnApproval[]

  @@index([workspaceId, status])
  @@index([workspaceId, sortOrder])
  @@map("mn_projects")
}

model MnProjectMember {
  id        String   @id @default(uuid()) @db.VarChar
  projectId String   @map("project_id") @db.VarChar
  userId    String   @map("user_id") @db.VarChar
  roleLabel String?  @map("role_label") @db.VarChar
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  project MnProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@map("mn_project_members")
}

model MnTask {
  id              String         @id @default(uuid()) @db.VarChar
  projectId       String         @map("project_id") @db.VarChar
  title           String         @db.VarChar
  description     String?        @db.Text
  status          MnTaskStatus   @default(TODO)
  priority        MnTaskPriority @default(NONE)
  dueAt           DateTime?      @map("due_at") @db.Timestamptz(3)
  listSortOrder   Int            @default(0) @map("list_sort_order")
  assigneeUserId  String?        @map("assignee_user_id") @db.VarChar
  /// M2: optional agent assignee. XOR with `assigneeUserId` — at most one
  /// of the two may be non-null. Prisma cannot express XOR declaratively,
  /// so the service layer rejects both-set writes with BadRequestException.
  assigneeAgentId String?        @map("assignee_agent_id") @db.VarChar
  /// M2: optional link to the goal this task contributes to. SetNull on
  /// goal delete so task history survives goal removal.
  goalId          String?        @map("goal_id") @db.VarChar
  /// M2: optional parent task. Self-ref forms an ancestry tree used by
  /// MnGoalContextService to render the task's place in the hierarchy.
  /// Cycle prevention is enforced at the service layer (max-depth walk).
  parentTaskId    String?        @map("parent_task_id") @db.VarChar
  /// M2: opaque routine-run id that triggered this task. VarChar (not FK)
  /// because runs can live in foreign scopes (MCP callers, external
  /// schedulers); free text so attribution can survive schema drift.
  originRunId     String?        @map("origin_run_id") @db.VarChar
  /// M2: time the task transitioned out of BACKLOG / TODO.
  startedAt       DateTime?      @map("started_at") @db.Timestamptz(3)
  /// M2: time the task moved to DONE. Null while in flight.
  completedAt     DateTime?      @map("completed_at") @db.Timestamptz(3)
  /// M2: time the task moved to CANCELLED. Null when not cancelled.
  cancelledAt     DateTime?      @map("cancelled_at") @db.Timestamptz(3)
  createdByUserId String?        @map("created_by_user_id") @db.VarChar
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)

  project       MnProject        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee      User?            @relation("MnTaskAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  agentAssignee MnAgent?         @relation("MnTaskAgentAssignee", fields: [assigneeAgentId], references: [id], onDelete: SetNull)
  goal          MnGoal?          @relation(fields: [goalId], references: [id], onDelete: SetNull)
  parent        MnTask?          @relation("MnTaskParent", fields: [parentTaskId], references: [id], onDelete: SetNull)
  children      MnTask[]         @relation("MnTaskParent")
  createdBy     User?            @relation("MnTaskCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  comments      MnTaskComment[]
  activities    MnTaskActivity[]
  costEvents    MnCostEvent[]
  blockedBy     MnTaskBlocker[]  @relation("MnTaskBlockedBy")
  blocking      MnTaskBlocker[]  @relation("MnTaskBlocking")
  aiSessions    AiSession[]

  @@index([projectId, status])
  @@index([projectId, listSortOrder])
  @@index([assigneeUserId])
  @@index([assigneeAgentId])
  @@index([goalId])
  @@index([parentTaskId])
  @@index([dueAt])
  @@map("mn_tasks")
}

model MnTaskComment {
  id        String   @id @default(uuid()) @db.VarChar
  taskId    String   @map("task_id") @db.VarChar
  authorId  String   @map("author_id") @db.VarChar
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  task   MnTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
