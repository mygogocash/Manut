// --- Manut M1: Agent identity + adapter system ---

enum MnAgentAdapterType {
  COPILOT_CHAT_SESSION
  E2B_SANDBOX
  CURSOR_CLOUD
  HTTP_WEBHOOK
  PROCESS_COMMAND
}

enum MnAgentStatus {
  IDLE
  RUNNING
  PAUSED
  ERROR
  TERMINATED
}

enum MnHeartbeatInvocationSource {
  CHAT_TURN
  MANUAL
  SCHEDULED
}

enum MnHeartbeatRunStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

/// Manut Agent — runtime instance of an MnAgentRole template. Project-scoped
/// per §5.1 (project = "company"). Adapter-typed; M1 only supports
/// COPILOT_CHAT_SESSION binding via AiSession.agentId.
model MnAgent {
  id               String             @id @default(uuid()) @db.VarChar
  workspaceId      String             @map("workspace_id") @db.VarChar
  projectId        String             @map("project_id") @db.VarChar
  roleId           String?            @map("role_id") @db.VarChar
  name             String             @db.VarChar
  adapterType      MnAgentAdapterType @default(COPILOT_CHAT_SESSION) @map("adapter_type")
  adapterConfig    Json               @default("{}") @map("adapter_config") @db.JsonB
  runtimeConfig    Json               @default("{}") @map("runtime_config") @db.JsonB
  status           MnAgentStatus      @default(IDLE)
  reportsToAgentId String?            @map("reports_to_agent_id") @db.VarChar
  capabilities     String?            @db.Text
  /// M12 — MAXIMIZER MODE flag. When true, the orchestrator applies a
  /// stricter execution policy: auto-delegation to subordinates,
  /// batched heartbeat scheduling (10 tool calls per batch), automatic
  /// approval gating when a tool call costs >50% of remaining budget,
  /// and mandatory full M11 outcome verification on every DONE
  /// transition (not just the opt-in DoD path). Default false so
  /// existing agents are unaffected until an operator explicitly opts
  /// in via `enableMnAgentMaximizer`.
  maximizerMode    Boolean            @default(false) @map("maximizer_mode")
  lastHeartbeatAt  DateTime?          @map("last_heartbeat_at") @db.Timestamptz(3)
  createdByUserId  String?            @map("created_by_user_id") @db.VarChar
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)

  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project            MnProject           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role               MnAgentRole?        @relation(fields: [roleId], references: [id], onDelete: SetNull)
  reportsTo          MnAgent?            @relation("MnAgentReportsTo", fields: [reportsToAgentId], references: [id], onDelete: SetNull)
  directReports      MnAgent[]           @relation("MnAgentReportsTo")
  createdBy          User?               @relation("MnAgentCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  apiKeys            MnAgentApiKey[]
  heartbeatRuns      MnHeartbeatRun[]
  aiSessions         AiSession[]
  costEvents         MnCostEvent[]
  requestedApprovals MnApproval[]        @relation("MnApprovalRequestedByAgent")
  approvalComments   MnApprovalComment[] @relation("MnApprovalCommentAuthorAgent")
  ownedGoals         MnGoal[]            @relation("MnGoalOwnerAgent")
  assignedTasks      MnTask[]            @relation("MnTaskAgentAssignee")
  executionRuns      MnExecutionRun[]
  memories           MnAgentMemory[]
  /// M10 — work products this agent produced. SetNull on agent delete:
  /// the artifact (PR, doc, deployment) outlives its producing agent
  /// so historical attribution survives agent decommissioning.
  workProducts       MnWorkProduct[]     @relation("MnWorkProductProducedBy")
  /// M14 — back-ref for work queues that default new intakes to this
  /// agent. SetNull on agent delete so the queue keeps routing rules
  /// intact and the operator can pick a replacement assignee later.
  workQueueDefaults  MnWorkQueue[]       @relation("MnWorkQueueDefaultAssignee")
  /// M15 — org-change proposals authored by this agent. SetNull on
  /// agent delete so the proposal + audit trail survives decommissioning
  /// of the proposer.
  proposedOrgChanges MnOrgChange[]       @relation("MnOrgChangeProposedByAgent")
  /// M13 — plans this agent authored. SetNull on agent delete: the
  /// plan revision survives so the historical record of "what did the
  /// strategy doc say before this task ran?" stays intact after the
  /// agent is decommissioned.
  authoredPlans      MnTaskPlan[]        @relation("MnTaskPlanAuthorAgent")

  @@index([workspaceId, projectId, status])
  @@index([workspaceId, reportsToAgentId])
  @@map("mn_agents")
}

/// M9 — Per-agent + per-task durable recall.
/// Kinds:
///   FACT       — Statement of truth ("user prefers TypeScript over Go").
///   DECISION   — Recorded choice that future runs should respect.
///   OBSERVATION — Free-form note captured during a run.
///   PLAYBOOK   — Reusable runbook fragment / how-to step.
enum MnMemoryKind {
  FACT
  DECISION
  OBSERVATION
  PLAYBOOK
}

/// M9 — Memory / Knowledge surface. Each row is a durable piece of recall
/// scoped to (workspaceId, agentId) with an optional taskId pin. The
/// auto-router prepends the top-N memories (ordered by importance desc,
/// then lastRetrievedAt desc) into the system message at session start.
///
/// `embedding` is reserved for future semantic recall (1024 dims to match
/// the M-class embedding model AFFiNE already ships with); nullable for
/// now so the M9 surface can land before the embedding job is wired.
///
/// `retrievedCount` + `lastRetrievedAt` form the recency component of the
/// ranking. `importance` (1-10) is operator-controlled and dominates.
/// `garbageCollect` reaps rows with `importance < threshold` older than a
/// cutoff to keep the recall surface narrow.
model MnAgentMemory {
  id              String       @id @default(uuid()) @db.VarChar
  workspaceId     String       @map("workspace_id") @db.VarChar
  projectId       String       @map("project_id") @db.VarChar
  agentId         String       @map("agent_id") @db.VarChar
  taskId          String?      @map("task_id") @db.VarChar
  kind            MnMemoryKind
  contentMd       String       @map("content_md") @db.Text
  embedding       Float[]      @default([])
  retrievedCount  Int          @default(0) @map("retrieved_count")
  lastRetrievedAt DateTime?    @map("last_retrieved_at") @db.Timestamptz(3)
  importance      Int          @default(1)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)

  agent MnAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  task  MnTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([workspaceId, agentId, importance(sort: Desc)])
  @@index([workspaceId, taskId])
  @@map("mn_agent_memories")
}

/// Bearer API key issued to a single MnAgent. Plaintext shown once at mint;
/// only key_hash stored. Prefix `mn_ak_` for log-scanning.
model MnAgentApiKey {
  id          String    @id @default(uuid()) @db.VarChar
  agentId     String    @map("agent_id") @db.VarChar
  workspaceId String    @map("workspace_id") @db.VarChar
  projectId   String    @map("project_id") @db.VarChar
  name        String    @db.VarChar
  keyHash     String    @unique @map("key_hash") @db.VarChar
  lastUsedAt  DateTime? @map("last_used_at") @db.Timestamptz(3)
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz(3)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  agent MnAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([workspaceId, projectId])
  @@map("mn_agent_api_keys")
}

/// Manut Heartbeat Run — one row per chat-turn (or scheduled wake or manual
/// invocation). Fire-and-forget emission from copilot session.ts; idempotent
/// on (agentId, externalRunId).
model MnHeartbeatRun {
  id               String                      @id @default(uuid()) @db.VarChar
  workspaceId      String                      @map("workspace_id") @db.VarChar
  projectId        String                      @map("project_id") @db.VarChar
  agentId          String                      @map("agent_id") @db.VarChar
  invocationSource MnHeartbeatInvocationSource @map("invocation_source")
  status           MnHeartbeatRunStatus
  aiSessionId      String?                     @map("ai_session_id") @db.VarChar
  startedAt        DateTime                    @default(now()) @map("started_at") @db.Timestamptz(3)
  finishedAt       DateTime?                   @map("finished_at") @db.Timestamptz(3)
  externalRunId    String?                     @map("external_run_id") @db.VarChar
  error            String?                     @db.Text

  agent     MnAgent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  aiSession AiSession? @relation(fields: [aiSessionId], references: [id], onDelete: SetNull)

  @@index([workspaceId, agentId, startedAt(sort: Desc)])
  @@index([aiSessionId])
  @@map("mn_heartbeat_runs")
}

/// Scope discriminator for an MnBudget row. The enforcer walks
/// task → goal → agent → project → workspace; first hard-stop match wins.
/// GOAL is a logical scope; the MnGoal model is owned by Branch B (M2) and
/// may land before or after M4. The `goalId` link on MnCostEvent is
/// deliberately a VarChar without a foreign key for the same reason.
enum MnBudgetScope {
  WORKSPACE
  PROJECT
  AGENT
  TASK
  GOAL
}

/// One row per LLM invocation that contributes to a tenant's spend.
/// Written fire-and-forget from the copilot providers (cost emission must
/// NEVER block a streaming response). The `goalId` link is intentionally
/// loose (no FK) so this migration applies cleanly whether M2 (MnGoal) is
/// merged or not — once Branch B ships the FK can be tightened later.
///
/// All money is denominated in **cents (USD)** as an Int to avoid floating
/// point comparison bugs in budget enforcement. Sub-cent costs round up at
/// emit time per the formula in `MnCostService.emit`.
model MnCostEvent {
  id           String   @id @default(uuid()) @db.VarChar
  workspaceId  String   @map("workspace_id") @db.VarChar
  projectId    String?  @map("project_id") @db.VarChar
  agentId      String?  @map("agent_id") @db.VarChar
  taskId       String?  @map("task_id") @db.VarChar
  /// Logical goal-scope link. Branch B (M2) owns MnGoal; once shipped we
  /// can tighten this to an FK with onDelete: SetNull.
  goalId       String?  @map("goal_id") @db.VarChar
  /// Optional billing classifier — e.g. customer/cost-center label. Free
  /// text so we don't paint ourselves into a corner before billing ships.
  billingCode  String?  @map("billing_code") @db.VarChar
  provider     String   @db.VarChar
  model        String   @db.VarChar
  inputTokens  Int      @default(0) @map("input_tokens")
  outputTokens Int      @default(0) @map("output_tokens")
  costCents    Int      @map("cost_cents")
  occurredAt   DateTime @default(now()) @map("occurred_at") @db.Timestamptz(3)

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   MnProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  agent     MnAgent?   @relation(fields: [agentId], references: [id], onDelete: SetNull)
  task      MnTask?    @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([workspaceId, occurredAt])
  @@index([workspaceId, projectId, occurredAt])
  @@index([workspaceId, agentId, occurredAt])
  @@map("mn_cost_events")
}

/// Monthly spend cap per scope. The enforcer aggregates against this row
/// every check; `spentCents` is a denormalized running total updated by
/// MnCostService at emit time so we don't sum millions of cost rows on
/// every chat turn. The unique tuple `(workspaceId, scopeType, scopeId,
/// monthYear)` makes upsert-on-create safe in race conditions.
///
/// `monthYear` is a YYYY-MM string (e.g. "2026-05") rather than a date
/// because budgets reset on calendar month boundaries and storing a date
/// makes range arithmetic in the enforcer surprising.
///
/// `scopeId` is nullable so a WORKSPACE budget can be expressed by
/// `scopeType=WORKSPACE, scopeId=null` without inventing a sentinel. The
/// @@unique tuple still functions correctly because Postgres treats NULL
/// values as distinct in unique constraints — meaning a single workspace
/// can have at most one WORKSPACE-scope budget per month (since `scopeId`
/// is always null for that scope).
model MnBudget {
  id               String        @id @default(uuid()) @db.VarChar
  workspaceId      String        @map("workspace_id") @db.VarChar
  projectId        String?       @map("project_id") @db.VarChar
  scopeType        MnBudgetScope @map("scope_type")
  scopeId          String?       @map("scope_id") @db.VarChar
  monthYear        String        @map("month_year") @db.VarChar
  capCents         Int           @map("cap_cents")
  spentCents       Int           @default(0) @map("spent_cents")
  warnThresholdPct Int           @default(80) @map("warn_threshold_pct")
  hardStopEnabled  Boolean       @default(true) @map("hard_stop_enabled")
  alertSent        Boolean       @default(false) @map("alert_sent")
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   MnProject? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, scopeType, scopeId, monthYear])
  @@index([workspaceId, scopeType])
  @@map("mn_budgets")
}

/// Manut Wave 6 (E1.12 — T-1.12.1.a) — per-workspace AI budget usage.
///
/// One row per (workspaceId, periodStart) tracks running monthly spend
/// in USD cents. Read by AiBudgetService.assertWithinCap to gate chat
/// invocations against the workspace's tier cap (FREE=$5, PRO=$50,
/// per IMPLEMENTATION_PLAN §0.3 decision #19 + #26 — same tiers exported
/// from packages/backend/server/src/core/quota/tiers.ts).
///
/// Distinct from MnBudget (which is scope-chained: project/agent/task/
/// goal/workspace). This is the simpler plan-tier ceiling that sits in
/// front of every chat turn; M4's scope-chain enforcer stays independent.
model MnAiBudgetUsage {
  workspaceId String   @map("workspace_id") @db.VarChar
  periodStart DateTime @map("period_start") @db.Timestamptz(3)
  spentCents  Int      @default(0) @map("spent_cents")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@id([workspaceId, periodStart])
  @@index([periodStart(sort: Desc)], map: "mn_ai_budget_usage_period_idx")
  @@map("mn_ai_budget_usage")
}

// ---------------------------------------------------------------------------
// M3 — Approvals + reviews
//
// Pending approvals block agent work; a single PENDING row of type
// TOOL_CALL_REVIEW is emitted by the copilot provider just before a write
// tool fires, the agent waits for a decision via SSE, and the gate cache
// (see `manut-approval-gate.service.ts`) keeps the per-workspace lookup
// sub-millisecond. State machine: PENDING → APPROVED/REJECTED/CANCELLED
// (terminal); PENDING → REVISION_REQUESTED → PENDING (mutable). Decided
// rows are immutable (enforced in `manut-approval.service.ts`).
//
// CLAUDE.md scars honored:
//  - Every nullable @Field on the matching DTOs uses the explicit
//    `() => Type` form (v1.7.0 / v1.10.2 UndefinedTypeError trap).
//  - `requestedByAgentId` + `decidedByUserId` use SetNull so deleting
//    the agent or user does NOT delete audit history.
//  - `approvalId` on MnApprovalComment uses Cascade so the comment
//    thread vanishes with the approval row.
// ---------------------------------------------------------------------------

enum MnApprovalType {
  HIRE_AGENT
  APPROVE_TASK_COMPLETION
  BUDGET_OVERRIDE
  REQUEST_BOARD_APPROVAL
  TOOL_CALL_REVIEW
  AGENT_ORG_CHANGE
}

enum MnApprovalStatus {
  PENDING
  REVISION_REQUESTED
  APPROVED
  REJECTED
  CANCELLED
}

/// Manut Approval — one pending or decided request for a human (or agent)
/// to authorize an action. Scoped to a workspace + project; the gate
/// service caches per-workspace pending counts in-memory with a 30s TTL.
model MnApproval {
  id                 String           @id @default(uuid()) @db.VarChar
  workspaceId        String           @map("workspace_id") @db.VarChar
  projectId          String           @map("project_id") @db.VarChar
  type               MnApprovalType
  requestedByAgentId String?          @map("requested_by_agent_id") @db.VarChar
  requestedByUserId  String?          @map("requested_by_user_id") @db.VarChar
  status             MnApprovalStatus @default(PENDING)
  payload            Json             @default("{}") @db.JsonB
  decisionNote       String?          @map("decision_note") @db.Text
  decidedByUserId    String?          @map("decided_by_user_id") @db.VarChar
  decidedAt          DateTime?        @map("decided_at") @db.Timestamptz(3)
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  workspace        Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project          MnProject           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requestedByAgent MnAgent?            @relation("MnApprovalRequestedByAgent", fields: [requestedByAgentId], references: [id], onDelete: SetNull)
  requestedByUser  User?               @relation("MnApprovalRequestedByUser", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  decidedByUser    User?               @relation("MnApprovalDecidedByUser", fields: [decidedByUserId], references: [id], onDelete: SetNull)
  comments         MnApprovalComment[]

  @@index([workspaceId, status, createdAt(sort: Desc)])
  @@index([workspaceId, projectId, status])
  @@index([requestedByAgentId])
  @@map("mn_approvals")
}

/// Comment attached to an approval. Comments survive decision (an APPROVED
/// approval can still be commented on for audit context) but are deleted
/// with the parent approval via Cascade.
model MnApprovalComment {
  id            String   @id @default(uuid()) @db.VarChar
  approvalId    String   @map("approval_id") @db.VarChar
  projectId     String   @map("project_id") @db.VarChar
  authorAgentId String?  @map("author_agent_id") @db.VarChar
  authorUserId  String?  @map("author_user_id") @db.VarChar
  body          String   @db.Text
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  approval    MnApproval @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  authorAgent MnAgent?   @relation("MnApprovalCommentAuthorAgent", fields: [authorAgentId], references: [id], onDelete: SetNull)
  authorUser  User?      @relation("MnApprovalCommentAuthorUser", fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([approvalId, createdAt])
  @@map("mn_approval_comments")
}

/// Manut M2 — goal hierarchy level. The chain runs PROJECT > TEAM > AGENT > TASK
/// (plus one flex slot for product-defined sub-levels); deeper than 5 is rejected
/// at the service layer to keep context-injection bounded.
enum MnGoalLevel {
  PROJECT
  TEAM
  AGENT
  TASK
}

/// Manut M2 — lifecycle state of a goal row.
enum MnGoalStatus {
  PLANNED
  ACTIVE
  ACHIEVED
  CANCELLED
}

/// Manut M2 — a single rung in the goal hierarchy. Goals own zero or many
/// `MnTask` rows via `MnTask.goalId`, and chain to a parent via
/// `parentGoalId`. The cycle / depth-limit invariants are enforced by
/// `MnGoalService`; Prisma cannot express either declaratively.
///
/// `ownerAgentId` is the agent the goal is delegated to, if any. Null means
/// the goal sits with a project owner / team (not assigned to a single
/// agent yet). SetNull on agent delete preserves the goal so we don't lose
/// strategy when an agent is decommissioned.
model MnGoal {
  id              String       @id @default(uuid()) @db.VarChar
  workspaceId     String       @map("workspace_id") @db.VarChar
  projectId       String       @map("project_id") @db.VarChar
  title           String       @db.VarChar
  description     String?      @db.Text
  level           MnGoalLevel
  parentGoalId    String?      @map("parent_goal_id") @db.VarChar
  ownerAgentId    String?      @map("owner_agent_id") @db.VarChar
  status          MnGoalStatus @default(PLANNED)
  createdByUserId String?      @map("created_by_user_id") @db.VarChar
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)

  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project    MnProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent     MnGoal?   @relation("MnGoalParent", fields: [parentGoalId], references: [id], onDelete: SetNull)
  children   MnGoal[]  @relation("MnGoalParent")
  ownerAgent MnAgent?  @relation("MnGoalOwnerAgent", fields: [ownerAgentId], references: [id], onDelete: SetNull)
  tasks      MnTask[]

  @@index([workspaceId, projectId, status])
  @@index([workspaceId, level])
  @@index([parentGoalId])
  @@index([ownerAgentId])
  @@map("mn_goals")
}

/// Manut M2 — explicit "task A blocked by task B" edge. We need this as a
/// separate join model (rather than denormalised on MnTask) because tasks
/// can be blocked by N other tasks and the relationship needs to outlive
/// the blocked task without dragging the blocker along. The blocker side
/// uses Restrict so that deleting a blocker doesn't silently unblock
/// downstream work — callers must explicitly remove the blocker edge first.
model MnTaskBlocker {
  id              String   @id @default(uuid()) @db.VarChar
  taskId          String   @map("task_id") @db.VarChar
  blockedByTaskId String   @map("blocked_by_task_id") @db.VarChar
  projectId       String   @map("project_id") @db.VarChar
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  task          MnTask @relation("MnTaskBlockedBy", fields: [taskId], references: [id], onDelete: Cascade)
  blockedByTask MnTask @relation("MnTaskBlocking", fields: [blockedByTaskId], references: [id], onDelete: Restrict)

  @@unique([taskId, blockedByTaskId])
  @@index([projectId])
  @@index([blockedByTaskId])
  @@map("mn_task_blockers")
}

// ---------------------------------------------------------------------------
// M5 — Skills layer + portability snapshot
//
// MnSkill is a workspace-scoped Markdown skill (think Claude Skills / AGENTS.md
// instructions). Each row holds the rendered Markdown plus a semver-like
// version string; the service enforces a version bump whenever `contentMd`
// changes so consumers can cache by version.
//
// MnExportSnapshot is the one-row-per-export receipt produced by the M5
// portability layer. The manifest carries a description of the export
// (workspaces, agents, skills, etc.); the SHA-256 of the canonical payload is
// stored uniquely so re-exporting the same content idempotently returns the
// existing snapshot row. `payloadBlobKey` is nullable because small payloads
// may be inlined elsewhere; large payloads point at an object-storage object.
// ---------------------------------------------------------------------------

enum MnSkillSource {
  BUILTIN
  WORKSPACE
  IMPORTED
}

model MnSkill {
  id          String        @id @default(uuid()) @db.VarChar
  workspaceId String        @map("workspace_id") @db.VarChar
  slug        String        @db.VarChar
  name        String        @db.VarChar
  description String?       @db.Text
  contentMd   String        @map("content_md") @db.Text
  version     String        @db.VarChar
  source      MnSkillSource @default(WORKSPACE)
  archivedAt  DateTime?     @map("archived_at") @db.Timestamptz(6)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, slug])
  @@index([workspaceId, source])
  @@index([workspaceId, archivedAt])
  @@map("mn_skills")
}

model MnExportSnapshot {
  id              String   @id @default(uuid()) @db.VarChar
  workspaceId     String   @map("workspace_id") @db.VarChar
  createdByUserId String?  @map("created_by_user_id") @db.VarChar
  manifest        Json     @db.JsonB
  sha256          String   @unique @db.VarChar
  byteSize        Int      @map("byte_size")
  payloadBlobKey  String?  @map("payload_blob_key") @db.VarChar
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdByUser User?     @relation("MnExportSnapshotsCreated", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([createdByUserId])
  @@map("mn_export_snapshots")
}

// M6a — Plugin runtime + IPC + capability gates.
//
// `MnPlugin` is the instance-scoped registry row: one per installed
// plugin package. The runtime spawns a `child_process.fork` worker
// per ENABLED row and supervises it via exponential backoff (see
// `plugin-runtime/manut-plugin-supervisor.service.ts`).
//
// `MnPluginConfig` is per-workspace plugin configuration. Optional
// `projectId` lets a plugin scope settings to a single project so
// the same plugin can run with different configs across projects
// inside one workspace.
enum MnPluginStatus {
  INSTALLED
  LOADING
  RUNNING
  CRASHED
  DISABLED
}

model MnPlugin {
  id            String         @id @default(uuid()) @db.VarChar
  name          String         @unique @db.VarChar
  version       String         @db.VarChar
  manifestJson  Json           @map("manifest_json") @db.JsonB
  packagePath   String?        @map("package_path") @db.VarChar
  processStatus MnPluginStatus @default(INSTALLED) @map("process_status")
  installedAt   DateTime       @default(now()) @map("installed_at") @db.Timestamptz(6)
  enabledAt     DateTime?      @map("enabled_at") @db.Timestamptz(6)
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  configs MnPluginConfig[]

  @@index([processStatus])
  @@map("mn_plugins")
}

model MnPluginConfig {
  id          String   @id @default(uuid()) @db.VarChar
  pluginId    String   @map("plugin_id") @db.VarChar
  workspaceId String   @map("workspace_id") @db.VarChar
  projectId   String?  @map("project_id") @db.VarChar
  configJson  Json     @default("{}") @map("config_json") @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  plugin    MnPlugin  @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([pluginId, workspaceId, projectId])
  @@index([workspaceId])
  @@map("mn_plugin_configs")
}

/// M14 — Work-queue intake status lifecycle. RECEIVED is the moment the
/// HTTP webhook lands; ROUTED is the post-rule terminal state when a
/// MnTask has been created; REJECTED is the terminal state when no
/// routing rule matched and the queue has no default assignee, or when
/// the payload failed validation.
enum MnIntakeStatus {
  RECEIVED
  ROUTED
  REJECTED
}

/// M14 — Manut Work Queue. Each queue is a per-project intake bucket
/// reachable via a single rotation-stable webhook URL
/// (`/api/work-queues/:intakeWebhookToken/intake`). Inbound payloads
/// are evaluated against `routingRules` in order; the first match
/// produces an MnTask + a MnWorkQueueIntake row linking back.
///
/// `routingRules` shape (validated at the service edge):
///   Array<{
///     match: { field: string; op: 'eq' | 'contains'; value: string };
///     assignToAgentId?: string;
///     assignToRoleSlug?: string;
///   }>
///
/// `field` is a JSONPath-ish dot-segment into the payload (`payload.foo.bar`
/// or just `foo` for the root); `op` is `eq` (exact) or `contains`
/// (case-insensitive substring). The service skips rules whose `field`
/// resolves to non-string for safety. If no rule matches and
/// `defaultAssigneeAgentId` is set, the task is created assigned to that
/// agent; otherwise the intake row records REJECTED.
model MnWorkQueue {
  id                     String         @id @default(uuid()) @db.VarChar
  workspaceId            String         @map("workspace_id") @db.VarChar
  projectId              String         @map("project_id") @db.VarChar
  name                   String         @db.VarChar
  description            String?        @db.Text
  /// Webhook token used in the public intake URL path. Globally unique
  /// (not just per-workspace) so a leaked token cannot collide with an
  /// unrelated workspace's queue. Rotated via the `rotateMnWorkQueueToken`
  /// mutation; old tokens become 404s the moment the rotation lands.
  intakeWebhookToken     String         @unique @map("intake_webhook_token") @db.VarChar
  routingRules           Json           @default("[]") @map("routing_rules") @db.JsonB
  defaultAssigneeAgentId String?        @map("default_assignee_agent_id") @db.VarChar
  defaultPriority        MnTaskPriority @default(LOW) @map("default_priority")
  isActive               Boolean        @default(true) @map("is_active")
  createdAt              DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt              DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)

  workspace       Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project         MnProject           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  defaultAssignee MnAgent?            @relation("MnWorkQueueDefaultAssignee", fields: [defaultAssigneeAgentId], references: [id], onDelete: SetNull)
  intakes         MnWorkQueueIntake[]

  @@index([workspaceId])
  @@index([projectId])
  @@index([defaultAssigneeAgentId])
  @@map("mn_work_queues")
}

/// M14 — One row per inbound webhook delivery. `payload` is the raw
/// JSON body the external system POSTed; we store it verbatim so the
/// audit log captures exactly what was received before any rule
/// evaluation. `externalRef` is an optional client-supplied id (e.g.
/// the support-ticket number) so the queue UI can dedupe and the
/// external system can link back. `routedToTaskId` is SetNull on task
/// delete so the intake row's audit trail survives task cleanup.
model MnWorkQueueIntake {
  id             String         @id @default(uuid()) @db.VarChar
  queueId        String         @map("queue_id") @db.VarChar
  externalRef    String?        @map("external_ref") @db.VarChar
  payload        Json           @db.JsonB
  status         MnIntakeStatus @default(RECEIVED)
  routedToTaskId String?        @map("routed_to_task_id") @db.VarChar
  receivedAt     DateTime       @default(now()) @map("received_at") @db.Timestamptz(3)

  queue        MnWorkQueue @relation(fields: [queueId], references: [id], onDelete: Cascade)
  routedToTask MnTask?     @relation(fields: [routedToTaskId], references: [id], onDelete: SetNull)

  @@index([queueId, receivedAt])
  @@index([status])
  @@index([externalRef])
  @@map("mn_work_queue_intakes")
}

/// M14 — Back-ref for MnProject so the project list query can pull its
/// queue count alongside other counts. Cascade on project delete is
/// the natural cleanup contract: queues are project-scoped, so a
/// deleted project takes its queues with it.
///
/// NOTE: this section reserved for future migration adding
/// MnProject.workQueues back-ref. For M14 we keep the relation lookup
/// on MnWorkQueue.project unidirectional to limit blast radius on the
/// MnProject model (which is already heavy with back-refs).

// M10 — Artifacts & Work Products.
//
// MnWorkProduct is the first-class registry row for ANY meaningful
// thing a task or agent produces: a doc, an uploaded file, an
// external URL, a pull request, a deployment, a CSV export, a
// screenshot. The artifact itself stays where it lives (BlockSuite
// docs in the docstore, files on R2/GCS, PRs in GitHub) — the
// registry stores only the *reference* (`ref` Text) plus enough
// metadata to render it in a list and re-open it.
//
// Ownership semantics:
//   - taskId is REQUIRED + Cascade — a work product without a task
//     to attribute it to is meaningless. When the task is deleted,
//     the registry row disappears with it. The underlying artifact
//     (doc / PR / URL) is owned by its external system and is NOT
//     touched.
//   - producedByAgentId is OPTIONAL + SetNull — work products
//     attributable to a human or to a since-decommissioned agent
//     still survive with a null producer. Historical attribution
//     beats foreign-key strictness.
enum MnWorkProductKind {
  DOC
  FILE
  URL
  PR
  DEPLOYMENT
  CSV
  SCREENSHOT
}

model MnWorkProduct {
  id                String            @id @default(uuid()) @db.VarChar
  workspaceId       String            @map("workspace_id") @db.VarChar
  projectId         String            @map("project_id") @db.VarChar
  taskId            String            @map("task_id") @db.VarChar
  producedByAgentId String?           @map("produced_by_agent_id") @db.VarChar
  kind              MnWorkProductKind
  /// Free-text reference: the URL, doc id, blob key, PR url,
  /// deployment id, etc. The shape varies by `kind` — interpretation
  /// is the caller's responsibility. NOT FK because targets live in
  /// foreign storage systems (GitHub, R2, BlockSuite docstore).
  ref               String            @db.Text
  /// Optional payload size in bytes for FILE/CSV/SCREENSHOT kinds.
  /// Null for kinds where size is meaningless (URL, PR, DEPLOYMENT).
  byteSize          Int?              @map("byte_size")
  title             String?           @db.VarChar
  description       String?           @db.Text
  /// Free-form per-kind metadata. Examples:
  ///   DOC          { docId, blockId? }
  ///   FILE / CSV   { mimeType, blobKey, filename }
  ///   URL          { domain, faviconUrl? }
  ///   PR           { repo, number, status, mergedAt? }
  ///   DEPLOYMENT   { environment, commitSha, deployedAt }
  ///   SCREENSHOT   { width, height, viewport }
  metadata          Json              @default("{}") @db.JsonB
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)

  task            MnTask   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  producedByAgent MnAgent? @relation("MnWorkProductProducedBy", fields: [producedByAgentId], references: [id], onDelete: SetNull)

  @@index([workspaceId, taskId, createdAt(sort: Desc)])
  @@index([producedByAgentId])
  @@map("mn_work_products")
}

/// M13 — Deep Planning lifecycle. Plans flow DRAFT → UNDER_REVIEW →
/// APPROVED | REJECTED. SUPERSEDED is set on the prior APPROVED plan
/// when a new APPROVED plan lands for the same task. The terminal
/// states (APPROVED, REJECTED, SUPERSEDED) never transition further;
/// the service layer enforces the state machine and refuses backward
/// transitions.
enum MnTaskPlanStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  REJECTED
  SUPERSEDED
}

/// M13 — Revisionable plan documents attached to a task. Strategy-heavy
/// tasks generate a plan body (markdown), receive review, and only the
/// APPROVED revision drives execution. `revisionNumber` is monotonic per
/// task — the service auto-increments via a max+1 within a transaction
/// so concurrent createPlan calls can't collide on the
/// `@@unique([taskId, revisionNumber])` constraint.
///
/// `authorAgentId` / `authorUserId` are XOR-soft (at most one set) so
/// the audit trail captures whether an agent or a human drafted the
/// plan. Both SetNull on delete to preserve the historical record after
/// agent/user cleanup. The service layer enforces XOR at write time.
///
/// `reviewerComments` is a JSONB array of free-form comment objects:
///   Array<{ authorUserId?: string; authorAgentId?: string;
///           body: string; createdAt: string }>
/// Appended to on every decision via `decidePlan`; never rewritten.
///
/// `status` follows the MnTaskPlanStatus state machine. When a plan
/// transitions to APPROVED, the service flips the prior APPROVED plan
/// (if any) on the same task to SUPERSEDED so the "current plan"
/// query is unambiguous: it's the row with status=APPROVED and the
/// highest revisionNumber.
model MnTaskPlan {
  id               String           @id @default(uuid()) @db.VarChar
  taskId           String           @map("task_id") @db.VarChar
  revisionNumber   Int              @map("revision_number")
  bodyMd           String           @map("body_md") @db.Text
  status           MnTaskPlanStatus @default(DRAFT)
  authorAgentId    String?          @map("author_agent_id") @db.VarChar
  authorUserId     String?          @map("author_user_id") @db.VarChar
  reviewerComments Json             @default("[]") @map("reviewer_comments") @db.JsonB
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)

  task        MnTask   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorAgent MnAgent? @relation("MnTaskPlanAuthorAgent", fields: [authorAgentId], references: [id], onDelete: SetNull)
  authorUser  User?    @relation("MnTaskPlanAuthorUser", fields: [authorUserId], references: [id], onDelete: SetNull)

  @@unique([taskId, revisionNumber])
  @@index([taskId, status])
  @@map("mn_task_plans")
}

/// M17 — CEO Chat. Role of the speaker on a given turn. USER is the
/// signed-in human; CEO_AGENT is the orchestrating LLM that classifies
/// intents and produces resolutions; SYSTEM is for internal banners
/// (resolution announcements, errors, etc).
enum MnCeoTurnRole {
  USER
  CEO_AGENT
  SYSTEM
}

/// M17 — CEO Chat. Typed resolution emitted by the CEO_AGENT for each
/// user turn. Drives the "every turn resolves to a typed work object"
/// invariant — the resolver creates a work object of the matching kind
/// (MnTask / MnApproval / MnTaskPlan / decision memory) and records its
/// id in `resolutionRefId`. NONE means the classifier could not pick a
/// resolution; the turn is still persisted for context.
enum MnCeoResolutionKind {
  NONE
  TASK_CREATED
  APPROVAL_REQUESTED
  PLAN_DRAFTED
  DECISION_RECORDED
  BUDGET_QUERY
  STATUS_QUERY
}

/// M17 — CEO Chat conversation. One per chat thread between the owner
/// (signed-in user) and the CEO agent. `lastResolutionKind` mirrors the
/// most-recent turn's resolution kind for cheap list rendering — it is
/// a denormalised cache, not an authoritative state. The authoritative
/// thread is the ordered set of `MnCeoTurn` rows.
model MnCeoConversation {
  id                 String               @id @default(uuid()) @db.VarChar
  workspaceId        String               @map("workspace_id") @db.VarChar
  ownerUserId        String               @map("owner_user_id") @db.VarChar
  title              String?              @db.VarChar
  lastResolutionKind MnCeoResolutionKind? @map("last_resolution_kind")
  createdAt          DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)

  owner     User        @relation("MnCeoConversationOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  turns     MnCeoTurn[]
  Workspace Workspace   @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, ownerUserId, updatedAt(sort: Desc)])
  @@map("mn_ceo_conversations")
}

/// M17 — CEO Chat turn. One row per message in a conversation. Cascade
/// on conversation delete — turn rows do not outlive their parent.
/// `resolutionRefId` is the id of the work object the resolution
/// created (e.g. an MnTask.id when kind=TASK_CREATED). VarChar (not
/// FK) because the target shape varies by kind — interpretation is the
/// resolver's responsibility.
model MnCeoTurn {
  id              String              @id @default(uuid()) @db.VarChar
  conversationId  String              @map("conversation_id") @db.VarChar
  role            MnCeoTurnRole
  bodyMd          String              @map("body_md") @db.Text
  resolutionKind  MnCeoResolutionKind @default(NONE) @map("resolution_kind")
  resolutionRefId String?             @map("resolution_ref_id") @db.VarChar
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)

  conversation MnCeoConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("mn_ceo_turns")
}

// ---------------------------------------------------------------------------
// Manut M15 — Self-Organization.
//
// Agents propose structural changes to the control plane (role
// adjustments, delegation re-wiring, new routines, hire requests,
// reporting/capability changes). Every proposal is paired with a sibling
// MnApproval row (type=AGENT_ORG_CHANGE) so the existing inbox / SSE
// surface gates the decision. After APPROVED, an operator can APPLY the
// change, which executes the structural edit (e.g. update
// MnAgent.reportsToAgentId, create an MnRoutine row). REVERT undoes an
// applied change when reversibility is possible.
//
// CLAUDE.md scars honored:
//  - SetNull on `proposedByAgentId` + `decidedByUserId` so the proposal
//    row survives proposer / decider deletion (audit trail).
//  - Cascade on `workspaceId` so the row vanishes with its workspace.
// ---------------------------------------------------------------------------

/// Kind of structural change proposed by an agent. The `payload` JSONB
/// column carries the type-specific shape; the service layer enforces
/// its schema per kind.
enum MnOrgChangeType {
  ROLE_ADJUSTMENT
  DELEGATION_CHANGE
  NEW_ROUTINE
  AGENT_HIRE_PROPOSAL
  REPORTING_CHANGE
  CAPABILITY_GRANT
}

/// Lifecycle state of a proposal. PROPOSED -> APPROVED|REJECTED ->
/// APPLIED -> REVERTED. REJECTED is terminal; APPLIED can transition
/// to REVERTED when `revert()` can reconstruct the prior state from
/// `payload.priorState`.
enum MnOrgChangeStatus {
  PROPOSED
  APPROVED
  REJECTED
  APPLIED
  REVERTED
}

/// Manut M15 — a single structural change proposal. The sibling
/// MnApproval (linked via `payload.approvalId` on this row) is the
/// human-decision gate; this row owns the structural intent + audit
/// trail and survives proposer / decider deletion via SetNull.
model MnOrgChange {
  id                String            @id @default(uuid()) @db.VarChar
  workspaceId       String            @map("workspace_id") @db.VarChar
  projectId         String            @map("project_id") @db.VarChar
  type              MnOrgChangeType
  proposedByAgentId String?           @map("proposed_by_agent_id") @db.VarChar
  status            MnOrgChangeStatus @default(PROPOSED)
  payload           Json              @default("{}") @db.JsonB
  rationale         String            @db.Text
  decisionNote      String?           @map("decision_note") @db.Text
  decidedByUserId   String?           @map("decided_by_user_id") @db.VarChar
  decidedAt         DateTime?         @map("decided_at") @db.Timestamptz(3)
  appliedAt         DateTime?         @map("applied_at") @db.Timestamptz(3)
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)

  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  proposedByAgent MnAgent?  @relation("MnOrgChangeProposedByAgent", fields: [proposedByAgentId], references: [id], onDelete: SetNull)
  decidedByUser   User?     @relation("MnOrgChangeDecidedByUser", fields: [decidedByUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status, createdAt(sort: Desc)])
  @@index([workspaceId, projectId, status])
  @@index([proposedByAgentId])
  @@map("mn_org_changes")
}
