model MnCrmDeal {
  id              String    @id @default(uuid()) @db.VarChar
  workspaceId     String    @map("workspace_id") @db.VarChar
  accountId       String?   @map("account_id") @db.VarChar
  contactId       String?   @map("contact_id") @db.VarChar
  stageId         String    @map("stage_id") @db.VarChar
  name            String    @db.VarChar
  value           Decimal?  @db.Decimal(18, 2)
  currency        String?   @default("USD") @db.VarChar(8)
  probability     Int?      @db.SmallInt
  expectedCloseAt DateTime? @map("expected_close_at") @db.Timestamptz(3)
  ownerUserId     String?   @map("owner_user_id") @db.VarChar
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
