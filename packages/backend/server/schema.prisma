model IntegrationConnection {
  id             String    @id @default(cuid()) @db.VarChar
  userId         String    @map("user_id") @db.VarChar
  workspaceId    String    @map("workspace_id") @db.VarChar
  provider       String    @db.VarChar
  externalId     String    @map("external_id") @db.VarChar
  displayName    String    @map("display_name") @db.VarChar
  // Encrypted at rest by IntegrationConnectionModel.encryptToken — never write
  // a plaintext value into these columns.
  accessToken    String    @map("encrypted_access_token") @db.Text
  refreshToken   String?   @map("encrypted_refresh_token") @db.Text
  tokenExpiresAt DateTime? @map("token_expires_at") @db.Timestamptz(3)
  scopes         String    @db.Text
  metadata       Json?     @db.JsonB
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId, provider])
  @@index([userId, workspaceId])
  @@map("integration_connections")
}

model McpApiKey {
  id          String    @id @default(cuid()) @db.VarChar
  userId      String    @map("user_id") @db.VarChar
  workspaceId String?   @map("workspace_id") @db.VarChar
  keyHash     String    @unique @map("key_hash") @db.VarChar
  name        String    @db.VarChar
  lastUsedAt  DateTime? @map("last_used_at") @db.Timestamptz(3)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz(3)

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, workspaceId])
  @@map("mcp_api_keys")
}

// Agents (Perplexity Spaces / Notion Agents-style).
// NOTE: Foreign-key columns are @db.VarChar to match the existing User.id and
// Workspace.id types, even though the spec mentioned @db.Uuid — Prisma requires
// FK column types to match the referenced columns exactly.
model Agent {
  id            String   @id @default(uuid()) @db.VarChar
  workspaceId   String   @map("workspace_id") @db.VarChar
  ownerId       String   @map("owner_id") @db.VarChar
  parentAgentId String?  @map("parent_agent_id") @db.VarChar
  name          String   @db.VarChar
  description   String   @default("") @db.Text
  instructions  String   @default("") @db.Text
  // skill ids (free-form strings)
  skills        String[] @default([]) @db.Text
  // [{url:string,label?:string},...]
  links         Json     @default("[]") @db.JsonB
  // blob storage keys / file ids referenced by the agent
  files         String[] @default([]) @db.Text
  // Picrew/Avataaars-style avatar configuration (free-form JSON object).
  // Renderer falls back to defaults for unknown keys; server does not validate.
  avatar        Json     @default("{}") @db.JsonB
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  parent    Agent?    @relation("AgentToSubAgents", fields: [parentAgentId], references: [id], onDelete: Cascade)
  subAgents Agent[]   @relation("AgentToSubAgents")
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner     User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([parentAgentId])
  @@map("agents")
}

// =============================================================================
// Analytics Platform — Phase 1 schema (docs/analytics-platform.md §5)
// =============================================================================
//
// Tables introduced:
//   social_connections  — workspace-level OAuth connections (KMS-encrypted tokens)
//   social_events       — normalized event store from webhooks/pollers
//   social_metrics      — pre-aggregated metric rollups (hour/day/week)
//   social_insights     — AI-generated insights with cost tracking
//   social_ai_budget    — monthly per-workspace AI spend cap
//   social_audit_logs   — audit trail for token decryption events (PRD §6)
//
// All tables are additive; nothing in the upstream schema is touched besides
// adding back-relations on User and Workspace. See migration
// `<timestamp>-analytics-platform.ts` for the idempotent SQL.

enum SocialPlatform {
  FACEBOOK
  INSTAGRAM
  THREADS
  TIKTOK
  LINE_VOOM
  GOGOCASH
}

enum ConnectionStatus {
  ACTIVE
  PAUSED
  EXPIRED
  ERROR
}

enum MetricBucket {
  HOUR
  DAY
  WEEK
}

enum InsightType {
  WEEKLY_STRATEGY
  TREND
  ANOMALY
  RECOMMENDATION
}

enum InsightSeverity {
  INFO
  NOTABLE
  ACTION_REQUIRED
}

model SocialConnection {
  id                  String           @id @default(uuid()) @db.VarChar
  workspaceId         String           @map("workspace_id") @db.VarChar
  platform            SocialPlatform
  status              ConnectionStatus @default(ACTIVE)
  // KMS-encrypted ciphertext. Never log or expose. See token-store.ts.
  accessTokenEnc      String           @map("access_token_enc") @db.Text
  refreshTokenEnc     String?          @map("refresh_token_enc") @db.Text
  scopes              String[]         @default([])
  externalAccountId   String           @map("external_account_id") @db.VarChar
  externalAccountName String           @map("external_account_name") @db.VarChar
  connectedByUserId   String           @map("connected_by_user_id") @db.VarChar
  expiresAt           DateTime?        @map("expires_at") @db.Timestamptz(3)
  lastSyncAt          DateTime?        @map("last_sync_at") @db.Timestamptz(3)
  lastErrorAt         DateTime?        @map("last_error_at") @db.Timestamptz(3)
  lastError           String?          @map("last_error") @db.Text
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  connectedBy User      @relation(fields: [connectedByUserId], references: [id])

  @@unique([workspaceId, platform, externalAccountId])
  @@index([workspaceId])
  @@index([status, expiresAt])
  @@map("social_connections")
}

model SocialEvent {
  id           String         @id @default(uuid()) @db.VarChar
  workspaceId  String         @map("workspace_id") @db.VarChar
  connectionId String         @map("connection_id") @db.VarChar
  platform     SocialPlatform
  eventType    String         @map("event_type") @db.VarChar
  externalId   String         @map("external_id") @db.VarChar
  occurredAt   DateTime       @map("occurred_at") @db.Timestamptz(3)
  receivedAt   DateTime       @default(now()) @map("received_at") @db.Timestamptz(3)
  payload      Json           @default("{}") @db.JsonB
  raw          Json           @default("{}") @db.JsonB

  @@unique([connectionId, externalId, eventType])
  @@index([workspaceId, occurredAt])
  @@index([workspaceId, platform, eventType, occurredAt])
  @@map("social_events")
}

model SocialMetric {
  id          String         @id @default(uuid()) @db.VarChar
  workspaceId String         @map("workspace_id") @db.VarChar
  platform    SocialPlatform
  metricKey   String         @map("metric_key") @db.VarChar
  bucket      MetricBucket
  bucketStart DateTime       @map("bucket_start") @db.Timestamptz(3)
  value       Float
  metadata    Json?          @db.JsonB

  @@unique([workspaceId, platform, metricKey, bucket, bucketStart])
  @@index([workspaceId, platform, bucket, bucketStart])
  @@map("social_metrics")
}

model SocialInsight {
  id               String           @id @default(uuid()) @db.VarChar
  workspaceId      String           @map("workspace_id") @db.VarChar
  insightType      InsightType      @map("insight_type")
  platforms        SocialPlatform[]
  title            String           @db.VarChar
  body             String           @db.Text
  severity         InsightSeverity
  modelUsed        String           @map("model_used") @db.VarChar
  costUsd          Float            @map("cost_usd")
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  acknowledgedAt   DateTime?        @map("acknowledged_at") @db.Timestamptz(3)
  acknowledgedById String?          @map("acknowledged_by_id") @db.VarChar

  @@index([workspaceId, createdAt])
  @@index([workspaceId, insightType, createdAt])
  @@map("social_insights")
}

model SocialAiBudget {
  id          String  @id @default(uuid()) @db.VarChar
  workspaceId String  @map("workspace_id") @db.VarChar
  monthYear   String  @map("month_year") @db.VarChar
  spentUsd    Float   @default(0) @map("spent_usd")
  capUsd      Float   @default(100) @map("cap_usd")
  alertSent   Boolean @default(false) @map("alert_sent")

  @@unique([workspaceId, monthYear])
  @@map("social_ai_budget")
}

// Audit trail for token decryption events. PRD §6 mandates a row per decrypt.
// We expose this as its own table because there is no existing audit_log
// facility in the upstream schema; agent 2 reads/writes via TokenStore only.
model SocialAuditLog {
  id          String         @id @default(uuid()) @db.VarChar
  workspaceId String         @map("workspace_id") @db.VarChar
  userId      String?        @map("user_id") @db.VarChar
  platform    SocialPlatform
  action      String         @db.VarChar
  requestId   String?        @map("request_id") @db.VarChar
  metadata    Json?          @db.JsonB
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([workspaceId, createdAt])
  @@index([userId, createdAt])
  @@map("social_audit_logs")
}

// --- Superflow: PM, CRM, reminders, notifications (workspace-scoped) ---

enum MnProjectStatus {
  ACTIVE
  ARCHIVED
}

enum MnTaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum MnTaskPriority {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MnCrmActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  OTHER
}

enum MnReminderStatus {
  SCHEDULED
  PROCESSING
  COMPLETED
  CANCELLED
  FAILED
}

enum MnReminderRuleTrigger {
  DATETIME
  OVERDUE_TASK
  INACTIVITY
  UPCOMING_DEADLINE
}

enum MnNotificationChannel {
  EMAIL
}

enum MnNotificationDeliveryStatus {
  PENDING
  QUEUED
  SENT
  FAILED
  SKIPPED
}

enum MnRoutineVisibility {
  PERSONAL
  WORKSPACE_SHARED
}

enum MnRoutineStatus {
  ACTIVE
  PAUSED
  ERROR
}

enum MnRoutineRunTrigger {
  MANUAL
  SCHEDULED
  MCP
}

enum MnRoutineRunStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
  TIMED_OUT
}

model MnProject {
  id              String          @id @default(uuid()) @db.VarChar
  workspaceId     String          @map("workspace_id") @db.VarChar
  name            String          @db.VarChar
  description     String?         @db.Text
  status          MnProjectStatus @default(ACTIVE)
  sortOrder       Int             @default(0) @map("sort_order")
  createdByUserId String?         @map("created_by_user_id") @db.VarChar
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(3)

  workspace  Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy  User?             @relation("MnProjectCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  members    MnProjectMember[]
  tasks      MnTask[]
  agents     MnAgent[]
  costEvents MnCostEvent[]
  budgets    MnBudget[]
  goals      MnGoal[]
  approvals  MnApproval[]
  workQueues MnWorkQueue[]

  @@index([workspaceId, status])
  @@index([workspaceId, sortOrder])
  @@map("mn_projects")
}

model MnProjectMember {
  id        String   @id @default(uuid()) @db.VarChar
  projectId String   @map("project_id") @db.VarChar
  userId    String   @map("user_id") @db.VarChar
  roleLabel String?  @map("role_label") @db.VarChar
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  project MnProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@map("mn_project_members")
}

model MnTask {
  id                String         @id @default(uuid()) @db.VarChar
  projectId         String         @map("project_id") @db.VarChar
  title             String         @db.VarChar
  description       String?        @db.Text
  status            MnTaskStatus   @default(TODO)
  priority          MnTaskPriority @default(NONE)
  dueAt             DateTime?      @map("due_at") @db.Timestamptz(3)
  listSortOrder     Int            @default(0) @map("list_sort_order")
  assigneeUserId    String?        @map("assignee_user_id") @db.VarChar
  /// M2: optional agent assignee. XOR with `assigneeUserId` — at most one
  /// of the two may be non-null. Prisma cannot express XOR declaratively,
  /// so the service layer rejects both-set writes with BadRequestException.
  assigneeAgentId   String?        @map("assignee_agent_id") @db.VarChar
  /// M2: optional link to the goal this task contributes to. SetNull on
  /// goal delete so task history survives goal removal.
  goalId            String?        @map("goal_id") @db.VarChar
  /// M2: optional parent task. Self-ref forms an ancestry tree used by
  /// MnGoalContextService to render the task's place in the hierarchy.
  /// Cycle prevention is enforced at the service layer (max-depth walk).
  parentTaskId      String?        @map("parent_task_id") @db.VarChar
  /// M2: opaque routine-run id that triggered this task. VarChar (not FK)
  /// because runs can live in foreign scopes (MCP callers, external
  /// schedulers); free text so attribution can survive schema drift.
  originRunId       String?        @map("origin_run_id") @db.VarChar
  /// M2: time the task transitioned out of BACKLOG / TODO.
  startedAt         DateTime?      @map("started_at") @db.Timestamptz(3)
  /// M2: time the task moved to DONE. Null while in flight.
  completedAt       DateTime?      @map("completed_at") @db.Timestamptz(3)
  /// M2: time the task moved to CANCELLED. Null when not cancelled.
  cancelledAt       DateTime?      @map("cancelled_at") @db.Timestamptz(3)
  /// M7 — atomic checkout + execution lock.
  ///
  /// `checkoutRunId` is the run id that holds the *checkout right* —
  /// the soft reservation taken before the run starts (e.g. a queue
  /// dispatcher claiming the task for itself). VarChar instead of an
  /// FK so external schedulers can populate it without an MnExecutionRun
  /// row existing yet.
  checkoutRunId     String?        @map("checkout_run_id") @db.VarChar
  /// `executionRunId` is the run id that holds the *execution lock* —
  /// taken atomically at the start of work via
  /// `MnTaskCheckoutService.tryCheckout`. Cleared on release or by
  /// the watchdog when the lock goes stale (>5 min without heartbeat).
  /// VarChar (not FK) for the same reason as checkoutRunId.
  executionRunId    String?        @map("execution_run_id") @db.VarChar
  /// Timestamp when the execution lock was last acquired. Used by the
  /// atomic `tryCheckout` SQL to detect stale locks
  /// (executionLockedAt < NOW() - INTERVAL '5 minutes' → freely
  /// re-acquirable). Cleared on release.
  executionLockedAt DateTime?      @map("execution_locked_at") @db.Timestamptz(3)
  /// Free-form execution-policy hints (max_attempts, retry_backoff_ms,
  /// approval_required, etc.). JSONB so we can grow the shape without
  /// migrations. The checkout service does not interpret it — it's a
  /// pass-through field for run dispatchers / agents.
  executionPolicy   Json?          @map("execution_policy") @db.JsonB
  /// Per-task execution state — last attempt number, last error,
  /// last heartbeat snapshot, etc. Free-form JSONB so dispatchers can
  /// stash arbitrary recovery context without schema churn.
  executionState    Json?          @map("execution_state") @db.JsonB
  /// M11 — Enforced Outcomes. An array of typed predicates declaring
  /// what "done" means for this task. The MnOutcomeVerifierService
  /// runs each predicate and refuses to transition the task to DONE
  /// unless every predicate is satisfied. JSONB so the predicate shape
  /// can grow without schema migrations.
  ///
  /// Schema (validated by Zod at the resolver edge):
  ///   Array<
  ///     | { kind: 'DOC_EXISTS', docId: string }
  ///     | { kind: 'URL_REACHABLE', url: string, expectedStatus?: number }
  ///     | { kind: 'WORK_PRODUCT_EXISTS', taskId: string, productKind?: string }
  ///     | { kind: 'EMBEDDING_SIMILARITY', sourceText: string, threshold: number }
  ///     | { kind: 'CUSTOM', description: string }
  ///   >
  ///
  /// `null` or `[]` means "no enforcement" — task transitions to DONE
  /// freely. Once populated, the status-transition guard in
  /// MnOutcomeVerifierService.assertCanTransitionToDone runs every
  /// predicate before allowing the status write.
  definitionOfDone  Json?          @map("definition_of_done") @db.JsonB
  createdByUserId   String?        @map("created_by_user_id") @db.VarChar
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)

  project       MnProject           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee      User?               @relation("MnTaskAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  agentAssignee MnAgent?            @relation("MnTaskAgentAssignee", fields: [assigneeAgentId], references: [id], onDelete: SetNull)
  goal          MnGoal?             @relation(fields: [goalId], references: [id], onDelete: SetNull)
  parent        MnTask?             @relation("MnTaskParent", fields: [parentTaskId], references: [id], onDelete: SetNull)
  children      MnTask[]            @relation("MnTaskParent")
  createdBy     User?               @relation("MnTaskCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  comments      MnTaskComment[]
  activities    MnTaskActivity[]
  costEvents    MnCostEvent[]
  blockedBy     MnTaskBlocker[]     @relation("MnTaskBlockedBy")
  blocking      MnTaskBlocker[]     @relation("MnTaskBlocking")
  aiSessions    AiSession[]
  executionRuns MnExecutionRun[]
  memories      MnAgentMemory[]
  /// M10 — first-class work products this task produced. Cascade on
  /// task delete: when a task disappears, its registry rows disappear
  /// too. The artifact itself (doc / PR / URL) is owned by an external
  /// system and is referenced by string, not deleted.
  workProducts  MnWorkProduct[]
  /// M14 — back-ref for work queue intakes that routed into this task.
  /// SetNull on task delete: the intake event row outlives its routed
  /// task so the audit trail (when did this ticket arrive, what queue
  /// routed it) survives the task's eventual cleanup.
  intakeRefs    MnWorkQueueIntake[]
  /// M13 — revisionable plan documents. Cascade on task delete: a plan
  /// is meaningless without its task. The service layer auto-increments
  /// `revisionNumber` so concurrent createPlan calls don't collide on
  /// the `@@unique([taskId, revisionNumber])` constraint.
  plans         MnTaskPlan[]

  @@index([projectId, status])
  @@index([projectId, listSortOrder])
  @@index([assigneeUserId])
  @@index([assigneeAgentId])
  @@index([goalId])
  @@index([parentTaskId])
  @@index([dueAt])
  @@index([executionRunId])
  @@map("mn_tasks")
}

/// M7 — Manut Execution Run. One row per attempt to execute a task.
/// Distinct from MnHeartbeatRun (which records chat-turn level keepalives)
/// because an execution run can span many chat-turns or none at all
/// (e.g. a batch worker).
///
/// Status lifecycle:
///   QUEUED → RUNNING → SUCCEEDED | FAILED | CANCELLED | TIMED_OUT
///
/// `agentId` is SetNull so a deleted agent doesn't cascade-delete the
/// historical record. `taskId` is Cascade because runs are meaningless
/// without their task.
enum MnExecutionRunStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
  TIMED_OUT
}

model MnExecutionRun {
  id         String               @id @default(uuid()) @db.VarChar
  taskId     String               @map("task_id") @db.VarChar
  agentId    String?              @map("agent_id") @db.VarChar
  status     MnExecutionRunStatus @default(QUEUED)
  startedAt  DateTime             @default(now()) @map("started_at") @db.Timestamptz(3)
  finishedAt DateTime?            @map("finished_at") @db.Timestamptz(3)
  error      String?              @db.Text

  task  MnTask   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agent MnAgent? @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([taskId, startedAt(sort: Desc)])
  @@index([status, startedAt])
  @@map("mn_execution_runs")
}

model MnTaskComment {
  id        String   @id @default(uuid()) @db.VarChar
  taskId    String   @map("task_id") @db.VarChar
  authorId  String   @map("author_id") @db.VarChar
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  task   MnTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User   @relation("MnTaskCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@map("mn_task_comments")
}

model MnTaskActivity {
  id        String   @id @default(uuid()) @db.VarChar
  taskId    String   @map("task_id") @db.VarChar
  actorId   String?  @map("actor_id") @db.VarChar
  action    String   @db.VarChar
  metadata  Json     @default("{}") @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  task  MnTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
