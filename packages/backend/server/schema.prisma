  stage      MnCrmDealStage  @relation(fields: [stageId], references: [id], onDelete: Restrict)
  owner      User?           @relation("MnCrmDealOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  activities MnCrmActivity[]

  @@index([workspaceId, stageId])
  @@index([accountId])
  @@index([contactId])
  @@index([ownerUserId])
  @@map("mn_crm_deals")
