# ============================================================================
# DISABLED — 2026-05-19
# ============================================================================
#
# This workflow assumed Railway was configured in IMAGE-PULL mode with
# `source.image = <gar-repo>:main`, then re-tagged GAR and called
# serviceInstanceDeployV2 to trigger a redeploy. Reality (as of 2026-05-19,
# verified via Dockerfile.railway comment + Railway dashboard screenshot):
# Railway is in GITHUB SOURCE-BUILD mode — it auto-pulls from main and builds
# with .docker/manut/Dockerfile.railway. There is no image-pull configured,
# so serviceInstanceDeployV2 returned the misleading "Not Authorized" catch-all
# on every run.
#
# This workflow being red also poisoned Railway's "Wait for CI" gate. Combined
# with manut-autodeploy.yml's failures, every recent commit's check suite
# showed up as "failed", so Railway SKIPPED the source-build redeploys —
# including PR #106's Dockerfile cache-mount fix. Disabling both removes the
# false-CI-failure noise and unblocks Railway's native auto-deploy.
#
# Disabled by renaming to .yml.disabled. CLAUDE.md §9 documents the new
# architecture (Railway source-build is the canonical path).
#
# To revive (if you want to switch back to image-pull):
#   1. In the Railway dashboard, set the Manut service Settings → Source from
#      "GitHub repo" to "Docker image" and point at <gar-repo>:main.
#   2. Verify the rolling tag exists in GAR.
#   3. Rename this file back to manut-railway-deploy.yml.
#   4. Workflow then re-tags the build's immutable tag as :main and calls
#      serviceInstanceDeployV2 to roll a new container. ~2 min vs ~25 min
#      source-build.
#
# Original content below this banner is unchanged for reference.
# ============================================================================

name: 🚂 Manut Railway Deploy
run-name: '🚂 Railway Deploy • ${{ github.event.workflow_run.head_sha || github.event.inputs.image_tag }} • by ${{ github.actor }}'

# Watches "🏗️ Manut Build" and points the Railway service at the new
# image SHA via a GAR rolling-tag swap, then triggers a Railway redeploy.
#
# WHY THIS DESIGN (and why the previous one didn't work):
# Previous v1.10.x version called `serviceInstanceUpdate(input: {
# source: { image: "..." }})`. Per Railway docs the `ServiceInstanceUpdateInput`
# type does NOT accept a `source` field — only build/runtime settings
# (buildCommand, startCommand, healthcheck, region, replicas, etc.).
# Railway rejected every call with a misleading "Not Authorized" error
# that's its catch-all for unknown input fields. The workflow had never
# succeeded; rotating RAILWAY_TOKEN never fixed it because the mutation
# shape itself was wrong. See CLAUDE.md §9 for the full diagnosis.
#
# THE WORKAROUND:
# 1. Build keeps pushing the immutable SHA tag (`main-<sha>-<runid>`)
#    to GAR — unchanged. GCP Auto Deploy still consumes immutable tags.
# 2. THIS workflow re-tags the freshly-built image as `:main` in GAR
#    via `gcloud artifacts docker tags add`. The immutable SHA tag
#    stays for rollback; the `:main` pointer moves to latest.
# 3. The Railway service is configured ONE-TIME with
#    `source.image = <gar-repo>:main` (no specific SHA).
# 4. We call `serviceInstanceDeployV2` to trigger a redeploy. Railway
#    resolves `:main` against GAR fresh and rolls a new container.
# 5. Healthcheck poll closes the loop.
#
# REQUIRED REPO SECRETS:
#   RAILWAY_TOKEN, RAILWAY_PROJECT_ID, RAILWAY_SERVICE_ID,
#   RAILWAY_ENVIRONMENT_ID — same as before.
#
# ONE-TIME RAILWAY DASHBOARD SETUP:
# Set the Railway service's source image to `<gar-repo>:main` (no SHA).
# manut-app → Settings → Source → replace the current `:main-<sha>-<runid>`
# tag with `:main`.
#
# EMOJI-FILTER TRAP (CLAUDE.md §9): If you rename "🏗️ Manut Build",
# update the `workflows:` filter below in the same PR.
#
# SECURITY: All user-controlled inputs (workflow_dispatch image_tag,
# artifact file content) pass through env vars and are validated
# against a strict alphanumeric/dash/dot/underscore regex before any
# shell or JSON use.

on:
  workflow_run:
    workflows: ['🏗️ Manut Build']
    types: [completed]
  workflow_dispatch:
    inputs:
      image_tag:
        description: 'Image tag to deploy. Empty = redeploy whatever :main currently points at.'
        type: string
        required: false
        default: ''

concurrency:
  group: railway-deploy
  cancel-in-progress: false

permissions:
  contents: read
  id-token: write
  # actions: read is required for actions/download-artifact@v4 to
  # read the image-tag artifact from the upstream Build workflow_run.
  # Without it, the workflow_run trigger path fails before resolving
  # the tag. (Codex review #80 / CLAUDE.md §9 token-scope trap.)
  actions: read

env:
  GAR_REPO: asia-southeast1-docker.pkg.dev/affine-495114/affine/affine-gogocash
  ROLLING_TAG: main
  RAILWAY_API: https://backboard.railway.com/graphql/v2

jobs:
  deploy:
    name: Deploy to Railway
    if: >
      github.event_name == 'workflow_dispatch' ||
      github.event.workflow_run.conclusion == 'success'
    runs-on: ubuntu-latest
    timeout-minutes: 15
    steps:
      - name: Download image-tag artifact (workflow_run path)
        if: github.event_name == 'workflow_run'
        uses: actions/download-artifact@v4
        with:
          name: image-tag
          path: ./artifact
          github-token: ${{ secrets.GITHUB_TOKEN }}
          run-id: ${{ github.event.workflow_run.id }}

      - name: Resolve + validate image tag
        id: tag
        env:
          EVENT_NAME: ${{ github.event_name }}
          DISPATCH_TAG: ${{ github.event.inputs.image_tag }}
        run: |
          set -eu

          if [ "$EVENT_NAME" = "workflow_dispatch" ] && [ -n "$DISPATCH_TAG" ]; then
            IMAGE_TAG="$DISPATCH_TAG"
            SOURCE="manual dispatch"
            HAS_TAG=yes
          elif [ -f ./artifact/image-tag.txt ]; then
            IMAGE_TAG=$(grep '^image_tag=' ./artifact/image-tag.txt | cut -d= -f2)
            SOURCE="Build artifact"
            HAS_TAG=yes
          else
            IMAGE_TAG=""
            SOURCE="redeploy current :main"
            HAS_TAG=no
          fi

          if [ "$HAS_TAG" = "yes" ]; then
            if ! printf '%s' "$IMAGE_TAG" | grep -qE '^[A-Za-z0-9._-]+$'; then
              echo "::error::Image tag failed validation: '$IMAGE_TAG'"
              exit 1
            fi
            echo "Using tag from $SOURCE: $IMAGE_TAG"
          else
            echo "No tag — will redeploy whatever :${ROLLING_TAG} currently points at."
          fi

          echo "tag=${IMAGE_TAG}" >> "$GITHUB_OUTPUT"
          echo "has_tag=${HAS_TAG}" >> "$GITHUB_OUTPUT"

      - name: Auth to GCP (Workload Identity Federation)
        if: steps.tag.outputs.has_tag == 'yes'
        uses: google-github-actions/auth@v2
        with:
          workload_identity_provider: 'projects/602860445793/locations/global/workloadIdentityPools/github-actions/providers/github'
          service_account: 'affine-gha-deployer@affine-495114.iam.gserviceaccount.com'

      - name: Set up gcloud
        if: steps.tag.outputs.has_tag == 'yes'
        uses: google-github-actions/setup-gcloud@v2

      - name: Re-tag GAR image as rolling tag
        if: steps.tag.outputs.has_tag == 'yes'
        env:
          IMAGE_TAG: ${{ steps.tag.outputs.tag }}
        run: |
          set -eu
          SRC="${GAR_REPO}:${IMAGE_TAG}"
          DST="${GAR_REPO}:${ROLLING_TAG}"
          echo "Re-tagging ${SRC} -> ${DST}"
          gcloud artifacts docker tags add "$SRC" "$DST"

      - name: Trigger Railway deploy
        id: deploy
        env:
          RAILWAY_TOKEN: ${{ secrets.RAILWAY_TOKEN }}
          SERVICE_ID: ${{ secrets.RAILWAY_SERVICE_ID }}
          ENVIRONMENT_ID: ${{ secrets.RAILWAY_ENVIRONMENT_ID }}
        run: |
          set -eu

          VARIABLES=$(jq -n \
            --arg sid "$SERVICE_ID" \
            --arg eid "$ENVIRONMENT_ID" \
            '{serviceId:$sid, environmentId:$eid}')

          read -r -d '' QUERY <<'EOF' || true
          mutation serviceInstanceDeployV2($serviceId: String!, $environmentId: String!) {
            serviceInstanceDeployV2(serviceId: $serviceId, environmentId: $environmentId)
          }
          EOF

          BODY=$(jq -n --arg q "$QUERY" --argjson v "$VARIABLES" '{query:$q, variables:$v}')

          RESPONSE=$(curl -sS --fail-with-body \
            -X POST "$RAILWAY_API" \
            -H "Authorization: Bearer ${RAILWAY_TOKEN}" \
            -H "Content-Type: application/json" \
            -d "$BODY")

          echo "Deploy response:"
          echo "$RESPONSE" | jq '.'

          if echo "$RESPONSE" | jq -e '.errors' >/dev/null 2>&1; then
            echo "::error::serviceInstanceDeployV2 returned errors. Check RAILWAY_TOKEN/SERVICE_ID/ENVIRONMENT_ID and that Railway source.image is set to :${ROLLING_TAG}."
            exit 1
          fi

          DEPLOY_ID=$(echo "$RESPONSE" | jq -r '.data.serviceInstanceDeployV2 // empty')
          echo "Deployment id: ${DEPLOY_ID:-(none returned)}"
          echo "deploy_id=${DEPLOY_ID}" >> "$GITHUB_OUTPUT"

      - name: Wait for healthcheck
        id: probe
        env:
          PROBE_URL: ${{ vars.RAILWAY_HEALTHCHECK_URL || 'https://manut-app-production.up.railway.app/info' }}
        run: |
          set -eu
          echo "Probing ${PROBE_URL}"
          for i in $(seq 1 60); do
            CODE=$(curl -sS -o /tmp/probe.body -w '%{http_code}' --max-time 8 "${PROBE_URL}" || echo "000")
            if [ "$CODE" = "200" ]; then
              echo "OK on attempt ${i}"
              cat /tmp/probe.body | head -c 200; echo
              exit 0
            fi
            echo "[${i}/60] HTTP ${CODE} — waiting 10s"
            sleep 10
          done
          echo "::error::Healthcheck never returned 200 after 10 minutes"
          exit 1

      - name: Summary
        if: always()
        env:
          IMAGE_TAG: ${{ steps.tag.outputs.tag }}
          HAS_TAG: ${{ steps.tag.outputs.has_tag }}
          JOB_STATUS: ${{ job.status }}
          DEPLOY_ID: ${{ steps.deploy.outputs.deploy_id }}
        run: |
          {
            echo "## Manut Railway Deploy"
            echo ""
            if [ "$HAS_TAG" = "yes" ]; then
              echo "- Re-tagged: \`${GAR_REPO}:${IMAGE_TAG}\` -> \`${GAR_REPO}:${ROLLING_TAG}\`"
            else
              echo "- Re-redeployed existing \`${GAR_REPO}:${ROLLING_TAG}\`"
            fi
            echo "- Deployment id: \`${DEPLOY_ID:-(unset)}\`"
            echo "- Status: ${JOB_STATUS}"
            echo ""
            echo "Rollback: re-run via workflow_dispatch with a previous \`main-<sha>-<runid>\` tag. The rolling \`:${ROLLING_TAG}\` pointer will move back to that SHA."
          } >> "$GITHUB_STEP_SUMMARY"
