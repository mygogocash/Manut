# Rust
target
*.node
tsconfig.node.tsbuildinfo
lib
# manut-landing keeps its data spine (siteConfig, plans, faqs, jsonld) in
# a project-local lib/ directory. The generic `lib` rule above would
# silently hide it and break the build. Unignore explicitly.
!manut-landing/lib/
!manut-landing/lib/**
affine.db
apps/web/next-routes.conf
.nx

packages/frontend/templates/edgeless
packages/frontend/core/public/static/templates

# script
af
af.cmd
*.resolved

# playwright
storageState.json
.gstack/

# AFFiNE-fork local artifacts
.claude/worktrees/

# Stale tsc emit shadows .css.ts/.tsx via rspack's resolve.extensions order
# (.js comes before .tsx). One stray src/**/index.css.js makes vanilla-extract
# silently skip the styles and React fails to mount. Keep these wiped.
packages/**/src/**/*.js
packages/**/src/**/*.js.map
blocksuite/**/src/**/*.js
blocksuite/**/src/**/*.js.map
# Worker entrypoints and other intentional .js files in src (mostly under
# apps/) are listed here as escape hatches if tsc-emit ever moves elsewhere.
