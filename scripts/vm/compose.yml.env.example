# Sample .env for /srv/affine/compose/.env
#
# deploy.sh maintains this file automatically — when it runs, it rewrites
# the three Superflow-owned variables below. Other entries (POSTGRES_PASSWORD,
# any custom overrides) are preserved. Keep secrets in /srv/affine/data/affine.env
# (referenced via env_file from compose-template.yml), NOT here.

REGISTRY=asia-southeast1-docker.pkg.dev/affine-495114/affine
LIVE_IMAGE_TAG=main-XXXXXXXXX-XXXXXXXXXXX
# IMAGE_TAG_OVERRIDE is set only while a canary sidecar is being smoke-
# tested. deploy.sh writes it before bringing the canary up and clears
# it again before swapping production. Leave blank in steady state.
IMAGE_TAG_OVERRIDE=
